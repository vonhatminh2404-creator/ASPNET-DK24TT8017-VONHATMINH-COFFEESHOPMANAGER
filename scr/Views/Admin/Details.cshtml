@model CoffeeShopManager.Models.SanPham

@{
    ViewData["Title"] = "Chi tiết sản phẩm";

    var imagePath = "";

    if (string.IsNullOrWhiteSpace(Model.HinhAnh))
    {
        imagePath = "";
    }
    else if (Model.HinhAnh.StartsWith("/") || Model.HinhAnh.StartsWith("http"))
    {
        imagePath = Model.HinhAnh;
    }
    else
    {
        imagePath = Url.Content("~/images/" + Model.HinhAnh);
    }
}

<style>
    .hoso-page {
        background: #f5f1e8;
        min-height: 100vh;
        padding: 40px 20px 60px;
        font-family: 'Merriweather', 'Noto Serif Display', 'Be Vietnam Pro', serif;
    }

    .hoso-sheet {
        max-width: 1050px;
        margin: 0 auto;
        background: #f8f6ef;
        border: 4px solid #4d5c4f;
        box-shadow: 0 10px 30px rgba(0,0,0,0.12);
        padding: 36px 38px 50px;
        position: relative;
    }

    .stamp-box {
        position: absolute;
        top: 28px;
        right: 28px;
        border: 5px solid #9ba19a;
        color: #8d948c;
        padding: 12px 22px;
        font-size: 20px;
        font-weight: 900;
        letter-spacing: 1px;
        transform: rotate(10deg);
        text-transform: uppercase;
        background: rgba(255,255,255,0.35);
    }

    .hoso-title {
        text-align: center;
        color: #8f2f24;
        font-size: 48px;
        font-weight: 900;
        text-transform: uppercase;
        margin-top: 10px;
        margin-bottom: 18px;
    }

    .hoso-line {
        border-bottom: 4px dashed #8f2f24;
        margin: 0 auto 34px;
        width: 92%;
    }

    .top-info-area {
        display: grid;
        grid-template-columns: 360px 1fr;
        gap: 34px;
        align-items: start;
        margin-bottom: 26px;
    }

    .image-section {
        width: 100%;
    }

    .image-label {
        display: block;
        font-size: 20px;
        font-weight: 900;
        color: #28404a;
        margin-bottom: 12px;
    }

    .image-box {
        width: 100%;
        height: 285px;
        border: 4px solid #4d5c4f;
        background: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
    }

        .image-box img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    .no-image {
        color: #7d7d7d;
        font-size: 18px;
        font-weight: 700;
        text-align: center;
        padding: 20px;
    }

    .top-fields {
        padding-top: 4px;
    }

    .field-group {
        margin-bottom: 30px;
    }

    .field-label {
        display: block;
        font-size: 20px;
        font-weight: 900;
        color: #28404a;
        margin-bottom: 14px;
    }

    .field-value {
        font-size: 20px;
        color: #6f7680;
        padding: 6px 8px 14px;
        border-bottom: 4px solid #4d5c4f;
        min-height: 40px;
        word-break: break-word;
    }

    .full-fields {
        margin-top: 10px;
    }

    .price-value {
        color: #8f2f24;
        font-weight: 900;
        font-size: 26px;
    }

    .status-visible {
        color: #1f8a3b;
        font-weight: 900;
    }

    .status-hidden {
        color: #c0392b;
        font-weight: 900;
    }

    .button-row {
        margin-top: 40px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 18px;
        flex-wrap: wrap;
    }

    .button-left,
    .button-right {
        display: flex;
        flex-wrap: wrap;
        gap: 14px;
        align-items: center;
    }

    .hoso-btn {
        min-width: 140px;
        height: 56px;
        padding: 0 24px;
        border: 4px solid #4d5c4f;
        background: transparent;
        color: #26404a;
        font-size: 18px;
        font-weight: 900;
        text-transform: uppercase;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: all 0.2s ease;
        font-family: 'Merriweather', 'Noto Serif Display', 'Be Vietnam Pro', serif;
    }

    .back-btn {
        background: transparent;
        color: #26404a;
    }

        .back-btn:hover {
            background: #e9e3d7;
            color: #26404a;
        }

    .edit-btn {
        background: #2f6fed;
        border-color: #2f6fed;
        color: white;
    }

        .edit-btn:hover {
            background: #1f55bd;
            color: white;
        }

    .delete-btn {
        background: #dc3545;
        border-color: #dc3545;
        color: white;
    }

        .delete-btn:hover {
            background: #b92a37;
            color: white;
        }

    .hide-btn {
        background: #6c757d;
        border-color: #6c757d;
        color: white;
    }

        .hide-btn:hover {
            background: #565e64;
            border-color: #565e64;
            color: white;
        }

    .inline-form {
        display: inline-block;
        margin: 0;
    }

    @@media (max-width: 850px) {
        .hoso-sheet {
            padding: 26px 20px 38px;
        }

        .stamp-box {
            position: static;
            transform: rotate(0deg);
            display: inline-block;
            margin-bottom: 18px;
        }

        .hoso-title {
            font-size: 34px;
        }

        .top-info-area {
            grid-template-columns: 1fr;
        }

        .image-box {
            height: 260px;
        }

        .field-label {
            font-size: 18px;
        }

        .field-value {
            font-size: 18px;
        }

        .button-row {
            flex-direction: column;
            align-items: stretch;
        }

        .button-left,
        .button-right {
            width: 100%;
            justify-content: center;
        }

        .hoso-btn {
            min-width: 130px;
        }
    }
</style>

<div class="hoso-page">
    <div class="hoso-sheet">
        <div class="stamp-box">Phiếu sản phẩm</div>

        <div class="hoso-title">Chi tiết sản phẩm</div>
        <div class="hoso-line"></div>

        <div class="top-info-area">
            <div class="image-section">
                <label class="image-label">Hình ảnh sản phẩm:</label>

                <div class="image-box">
                    @if (!string.IsNullOrWhiteSpace(imagePath))
                    {
                        <img src="@imagePath" alt="@Model.TenSP" />
                    }
                    else
                    {
                        <div class="no-image">Chưa có ảnh sản phẩm</div>
                    }
                </div>
            </div>

            <div class="top-fields">
                <div class="field-group">
                    <label class="field-label">Tên sản phẩm:</label>
                    <div class="field-value">@Model.TenSP</div>
                </div>

                <div class="field-group">
                    <label class="field-label">Mã sản phẩm:</label>
                    <div class="field-value">@Model.MaSP</div>
                </div>
            </div>
        </div>

        <div class="full-fields">
            <div class="field-group">
                <label class="field-label">Danh mục:</label>
                <div class="field-value">@(Model.DanhMuc?.TenDanhMuc ?? "Chưa có danh mục")</div>
            </div>

            <div class="field-group">
                <label class="field-label">Giá bán (VNĐ):</label>
                <div class="field-value price-value">@Model.Gia.ToString("N0")</div>
            </div>

            <div class="field-group">
                <label class="field-label">Trạng thái:</label>
                <div class="field-value">
                    @if (Model.IsAn)
                    {
                        <span class="status-hidden">Đang ẩn</span>
                    }
                    else
                    {
                        <span class="status-visible">Đang hiển thị</span>
                    }
                </div>
            </div>
        </div>

        <div class="button-row">
            <div class="button-left">
                <a asp-controller="Admin"
                   asp-action="Index"
                   class="hoso-btn back-btn">
                    ← Trở về
                </a>

                <a asp-controller="Admin"
                   asp-action="Edit"
                   asp-route-id="@Model.MaSP"
                   class="hoso-btn edit-btn">
                    Sửa
                </a>

                <a asp-controller="Admin"
                   asp-action="Delete"
                   asp-route-id="@Model.MaSP"
                   class="hoso-btn delete-btn">
                    Xóa
                </a>
            </div>

            <div class="button-right">
                <form asp-controller="Admin"
                      asp-action="AnHien"
                      asp-route-id="@Model.MaSP"
                      method="post"
                      class="inline-form">
                    @Html.AntiForgeryToken()

                    <button type="submit" class="hoso-btn hide-btn">
                        @(Model.IsAn ? "Hiện sản phẩm" : "Ẩn sản phẩm")
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>