@model CoffeeShopManager.Models.SanPham

@{
    ViewData["Title"] = "Sửa Thông Tin Món - BonFire Admin";
}

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Courier+Prime:ital,wght@0,400;0,700;1,400&family=Playfair+Display:ital,wght@0,700;1,700&display=swap');

    .create-container {
        font-family: 'Courier Prime', monospace;
        background-color: #F4F2EB;
        border: 3px solid #36453B;
        padding: 40px;
        max-width: 700px;
        margin: 50px auto;
        position: relative;
    }

        /* Con dấu đỏ thay đổi thành CHỈNH SỬA */
        .create-container::before {
            content: "BẢN CHỈNH SỬA";
            position: absolute;
            top: 20px;
            right: 20px;
            border: 4px double #d4a017;
            color: #d4a017;
            padding: 5px 15px;
            font-weight: bold;
            transform: rotate(15deg);
            opacity: 0.7;
        }

    .create-title {
        font-family: 'Playfair Display', serif;
        color: #36453B;
        text-align: center;
        text-transform: uppercase;
        border-bottom: 2px dashed #36453B;
        padding-bottom: 15px;
        margin-bottom: 30px;
    }

    .form-group label {
        font-weight: bold;
        color: #36453B;
        text-transform: uppercase;
        margin-bottom: 8px;
        display: block;
    }

    .form-control-custom {
        background-color: transparent;
        border: none;
        border-bottom: 2px solid #36453B;
        border-radius: 0;
        padding: 10px 5px;
        width: 100%;
        font-family: 'Courier Prime', monospace;
        margin-bottom: 20px;
        color: #2C2C2C;
    }

        .form-control-custom:focus {
            outline: none;
            background-color: #EBE4D5;
            border-bottom-color: #d4a017;
        }

    .cong-btn {
        background-color: transparent;
        border: 2px solid #36453B;
        color: #36453B;
        font-weight: bold;
        text-transform: uppercase;
        padding: 10px 25px;
        text-decoration: none;
        display: inline-block;
        transition: all 0.3s;
        cursor: pointer;
    }

    .cong-btn-save {
        background-color: #d4a017;
        color: #F4F2EB;
        border-color: #d4a017;
    }

        .cong-btn-save:hover {
            background-color: #b58812;
            border-color: #b58812;
        }

    .text-danger-custom {
        color: #8B2F29;
        font-size: 0.85rem;
        font-style: italic;
    }
</style>

<div class="container">
    <div class="create-container shadow">
        <h2 class="create-title">CHỈNH SỬA THÔNG TIN MÓN</h2>

        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger-custom mb-3"></div>

            <input type="hidden" asp-for="MaSP" />

            <div class="form-group mb-4">
                <label>Tên gọi sản phẩm:</label>
                <input asp-for="TenSP" class="form-control-custom" />
                <span asp-validation-for="TenSP" class="text-danger-custom"></span>
            </div>

            <div class="form-group mb-4">
                <label>Giá niêm yết (VNĐ):</label>
                <input asp-for="Gia" type="number" class="form-control-custom" />
                <span asp-validation-for="Gia" class="text-danger-custom"></span>
            </div>

            <div class="form-group mb-4">
                <label>Hình ảnh (Link ảnh):</label>
                <input asp-for="HinhAnh" class="form-control-custom" />
                <span asp-validation-for="HinhAnh" class="text-danger-custom"></span>
            </div>

            <div class="form-group mb-4">
                <label>Phân loại danh mục:</label>
                <select asp-for="MaDanhMuc" class="form-control-custom" asp-items="@ViewBag.DanhSachMenu">
                    <option value="">-- Chọn danh mục --</option>
                </select>
                <span asp-validation-for="MaDanhMuc" class="text-danger-custom"></span>
            </div>

            <div class="d-flex justify-content-between align-items-center mt-5">
                <a asp-action="Index" class="cong-btn">← QUAY LẠI KHO</a>
                <button type="submit" class="cong-btn cong-btn-save">LƯU THAY ĐỔI ✓</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}