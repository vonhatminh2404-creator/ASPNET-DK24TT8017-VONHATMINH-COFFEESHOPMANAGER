@model CoffeeShopManager.Models.DanhMuc

@{
    ViewData["Title"] = "Thêm danh mục";
}

<style>
    .form-page {
        min-height: 100vh;
        background: #f5f1e8;
        padding: 45px 30px 70px;
        font-family: 'Merriweather', 'Noto Serif Display', 'Be Vietnam Pro', serif;
    }

    .form-sheet {
        max-width: 820px;
        margin: 0 auto;
        background: #f8f6ef;
        border: 4px solid #4d5c4f;
        padding: 36px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.12);
    }

    .form-title {
        text-align: center;
        color: #8f2f24;
        font-size: 42px;
        font-weight: 900;
        text-transform: uppercase;
        margin-bottom: 18px;
    }

    .form-line {
        border-bottom: 4px dashed #8f2f24;
        margin: 0 auto 30px;
        width: 92%;
    }

    .form-group {
        margin-bottom: 26px;
    }

    .form-label {
        display: block;
        color: #28404a;
        font-size: 19px;
        font-weight: 900;
        margin-bottom: 10px;
    }

    .form-control-custom {
        width: 100%;
        border: none;
        border-bottom: 4px solid #4d5c4f;
        background: transparent;
        padding: 10px 8px;
        font-size: 18px;
        font-weight: 700;
        color: #28404a;
        outline: none;
    }

    .text-danger {
        color: #dc3545;
        font-weight: 900;
        display: block;
        margin-top: 8px;
    }

    .button-row {
        margin-top: 34px;
        display: flex;
        justify-content: space-between;
        gap: 16px;
        flex-wrap: wrap;
    }

    .back-btn,
    .submit-btn {
        min-width: 170px;
        height: 54px;
        border: 4px solid #4d5c4f;
        font-size: 18px;
        font-weight: 900;
        text-transform: uppercase;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
    }

    .back-btn {
        color: #26404a;
        background: transparent;
    }

        .back-btn:hover {
            background: #e9e3d7;
            color: #26404a;
        }

    .submit-btn {
        background: #3d5343;
        color: white;
    }

        .submit-btn:hover {
            background: #2f4335;
        }
</style>

<div class="form-page">
    <div class="form-sheet">
        <h1 class="form-title">Thêm danh mục</h1>
        <div class="form-line"></div>

        <form asp-controller="DanhMuc" asp-action="Create" method="post">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group">
                <label asp-for="TenDanhMuc" class="form-label">Tên danh mục:</label>
                <input asp-for="TenDanhMuc" class="form-control-custom" placeholder="Ví dụ: Cà phê, Trà, Nước ép..." />
                <span asp-validation-for="TenDanhMuc" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="MoTa" class="form-label">Mô tả:</label>
                <textarea asp-for="MoTa"
                          class="form-control-custom"
                          rows="4"
                          placeholder="Nhập mô tả ngắn cho danh mục..."></textarea>
                <span asp-validation-for="MoTa" class="text-danger"></span>
            </div>

            <div class="button-row">
                <a asp-controller="DanhMuc" asp-action="Index" class="back-btn">
                    ← Trở về
                </a>

                <button type="submit" class="submit-btn">
                    Lưu danh mục
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}