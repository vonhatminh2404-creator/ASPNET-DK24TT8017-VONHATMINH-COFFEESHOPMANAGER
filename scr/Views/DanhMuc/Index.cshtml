@model IEnumerable<CoffeeShopManager.Models.DanhMuc>

@{
    ViewData["Title"] = "Quản lý danh mục";
}

<style>
    .category-page {
        min-height: 100vh;
        background: #f5f1e8;
        padding: 45px 30px 70px;
        font-family: 'Merriweather', 'Noto Serif Display', 'Be Vietnam Pro', serif;
    }

    .category-sheet {
        max-width: 1150px;
        margin: 0 auto;
        background: #f8f6ef;
        border: 4px solid #4d5c4f;
        padding: 36px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.12);
    }

    .category-title {
        text-align: center;
        color: #8f2f24;
        font-size: 44px;
        font-weight: 900;
        text-transform: uppercase;
        margin-bottom: 18px;
    }

    .category-line {
        border-bottom: 4px dashed #8f2f24;
        margin: 0 auto 30px;
        width: 92%;
    }

    .success-message {
        background: #e6f4ea;
        color: #1f7a3b;
        border: 2px solid #1f7a3b;
        padding: 14px 18px;
        margin-bottom: 24px;
        font-weight: 900;
    }

    .error-message {
        background: #fdecea;
        color: #b42318;
        border: 2px solid #b42318;
        padding: 14px 18px;
        margin-bottom: 24px;
        font-weight: 900;
    }

    .top-actions {
        display: flex;
        justify-content: space-between;
        gap: 14px;
        flex-wrap: wrap;
        margin-bottom: 24px;
    }

    .category-btn {
        min-width: 190px;
        height: 52px;
        border: 4px solid #4d5c4f;
        color: #26404a;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-weight: 900;
        text-transform: uppercase;
        background: transparent;
    }

        .category-btn:hover {
            background: #e9e3d7;
            color: #26404a;
        }

    .main-btn {
        background: #3d5343;
        color: white;
    }

        .main-btn:hover {
            background: #2f4335;
            color: white;
        }

    .table-wrap {
        width: 100%;
        overflow-x: auto;
    }

    .category-table {
        width: 100%;
        border-collapse: collapse;
        min-width: 850px;
    }

        .category-table th {
            background: #3d5343;
            color: white;
            padding: 14px;
            text-align: center;
            text-transform: uppercase;
            font-size: 15px;
        }

        .category-table td {
            border-bottom: 3px solid #4d5c4f;
            padding: 16px 10px;
            text-align: center;
            color: #28404a;
            font-weight: 800;
            vertical-align: middle;
        }

    .desc-cell {
        text-align: left;
        max-width: 380px;
    }

    .count-badge {
        display: inline-block;
        min-width: 42px;
        padding: 7px 12px;
        border-radius: 999px;
        background: #fff3cd;
        color: #856404;
        border: 1px solid #d6a700;
        font-weight: 900;
    }

    .action-btn {
        display: inline-block;
        padding: 9px 14px;
        margin: 2px;
        color: white;
        text-decoration: none;
        font-weight: 900;
        border-radius: 6px;
        white-space: nowrap;
    }

    .detail-btn {
        background: #3d5343;
    }

    .edit-btn {
        background: #2f6fed;
    }

    .delete-btn {
        background: #dc3545;
    }

    .action-btn:hover {
        opacity: 0.88;
        color: white;
    }

    .empty-text {
        text-align: center;
        color: #28404a;
        font-size: 22px;
        font-weight: 900;
        padding: 35px;
    }
</style>

<div class="category-page">
    <div class="category-sheet">
        <h1 class="category-title">Quản lý danh mục</h1>
        <div class="category-line"></div>

        @if (TempData["Success"] != null)
        {
            <div class="success-message">
                @TempData["Success"]
            </div>
        }

        @if (TempData["Error"] != null)
        {
            <div class="error-message">
                @TempData["Error"]
            </div>
        }

        <div class="top-actions">
            <a asp-controller="Admin" asp-action="Dashboard" class="category-btn">
                ← Dashboard
            </a>

            <a asp-controller="DanhMuc" asp-action="Create" class="category-btn main-btn">
                + Thêm danh mục
            </a>
        </div>

        @if (Model == null || !Model.Any())
        {
            <div class="empty-text">
                Chưa có danh mục nào.
            </div>
        }
        else
        {
            <div class="table-wrap">
                <table class="category-table">
                    <thead>
                        <tr>
                            <th>Mã</th>
                            <th>Tên danh mục</th>
                            <th>Mô tả</th>
                            <th>Số sản phẩm</th>
                            <th>Thao tác</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>#@item.MaDanhMuc</td>

                                <td>@item.TenDanhMuc</td>

                                <td class="desc-cell">
                                    @(string.IsNullOrWhiteSpace(item.MoTa) ? "Chưa có mô tả" : item.MoTa)
                                </td>

                                <td>
                                    <span class="count-badge">
                                        @(item.SanPhams == null ? 0 : item.SanPhams.Count)
                                    </span>
                                </td>

                                <td>
                                    <a asp-controller="DanhMuc"
                                       asp-action="Details"
                                       asp-route-id="@item.MaDanhMuc"
                                       class="action-btn detail-btn">
                                        Xem
                                    </a>

                                    <a asp-controller="DanhMuc"
                                       asp-action="Edit"
                                       asp-route-id="@item.MaDanhMuc"
                                       class="action-btn edit-btn">
                                        Sửa
                                    </a>

                                    <a asp-controller="DanhMuc"
                                       asp-action="Delete"
                                       asp-route-id="@item.MaDanhMuc"
                                       class="action-btn delete-btn">
                                        Xóa
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>