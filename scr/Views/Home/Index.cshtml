@model IEnumerable<CoffeeShopManager.Models.SanPham>

@{
    ViewData["Title"] = "Thực Đơn";

    string keyword = ViewBag.Keyword as string ?? "";
    int? danhMucId = ViewBag.DanhMucId as int?;
    decimal? giaTu = ViewBag.GiaTu as decimal?;
    decimal? giaDen = ViewBag.GiaDen as decimal?;
}

<style>
    .menu-page {
        background-color: #6f6259;
        min-height: 100vh;
        padding: 45px 55px 70px;
        font-family: 'Merriweather', 'Noto Serif Display', 'Be Vietnam Pro', serif;
    }

    .menu-title {
        text-align: center;
        color: #4b2e1f;
        background-color: #f8f5ec;
        padding: 22px 10px;
        margin: -45px -55px 35px;
        font-size: 34px;
        font-weight: 900;
        letter-spacing: 3px;
        text-transform: uppercase;
        border-bottom: 1px solid #d8cfc2;
    }

        .menu-title span {
            display: inline-block;
            border-bottom: 2px dashed #4b2e1f;
            padding-bottom: 8px;
        }

    .filter-box {
        background: #f8f1df;
        border: 2px solid #d1a856;
        border-radius: 20px;
        padding: 22px;
        margin-bottom: 35px;
        box-shadow: 0 10px 22px rgba(0, 0, 0, 0.25);
    }

    .filter-title {
        color: #3b2a20;
        font-size: 24px;
        font-weight: 900;
        margin-bottom: 18px;
        text-transform: uppercase;
    }

    .filter-form {
        display: grid;
        grid-template-columns: 2fr 1.4fr 1fr 1fr auto auto;
        gap: 14px;
        align-items: end;
    }

    .filter-group label {
        display: block;
        color: #3b2a20;
        font-size: 15px;
        font-weight: 900;
        margin-bottom: 6px;
    }

    .filter-control {
        width: 100%;
        height: 42px;
        border: 1px solid #b88a3b;
        border-radius: 10px;
        padding: 8px 12px;
        background-color: #fffaf0;
        color: #2f241d;
        font-weight: 700;
    }

    .filter-btn,
    .reset-btn {
        height: 42px;
        border-radius: 10px;
        padding: 0 18px;
        font-weight: 900;
        text-transform: uppercase;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        white-space: nowrap;
    }

    .filter-btn {
        border: none;
        background: #3b2a20;
        color: #fff8df;
    }

        .filter-btn:hover {
            background: #7b3f20;
        }

    .reset-btn {
        border: 1px solid #3b2a20;
        color: #3b2a20;
        background: transparent;
    }

        .reset-btn:hover {
            background: #3b2a20;
            color: white;
        }

    .category-nav {
        margin-bottom: 38px;
        padding: 24px 28px;
        background: rgba(248, 245, 236, 0.16);
        border: 1px solid rgba(255, 235, 180, 0.35);
        border-radius: 18px;
    }

        .category-nav h3 {
            color: #ffd84d;
            font-size: 24px;
            font-weight: 900;
            margin-bottom: 18px;
            text-transform: uppercase;
        }

    .category-list {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        padding: 0;
        margin: 0;
        list-style: none;
    }

        .category-list a {
            display: inline-block;
            padding: 9px 18px;
            background-color: #f8f5ec;
            color: #3b2a20;
            border-radius: 999px;
            text-decoration: none;
            font-weight: 800;
            border: 1px solid #d4b06a;
            box-shadow: 0 4px 10px rgba(0, 0, 0, 0.18);
        }

            .category-list a:hover {
                background-color: #ffd84d;
                color: #2c1c14;
            }

    .category-section {
        margin-bottom: 55px;
    }

    .category-title {
        color: #ffd84d;
        font-size: 32px;
        font-weight: 900;
        margin-bottom: 28px;
        text-transform: uppercase;
        letter-spacing: 1px;
        text-shadow: 1px 1px 2px rgba(0, 0, 0, 0.35);
    }

    .product-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(240px, 1fr));
        gap: 34px;
    }

    .product-card {
        background: linear-gradient(180deg, #f8f1df 0%, #efe2c5 100%);
        border: 2px solid #d1a856;
        border-radius: 24px;
        padding: 20px 20px 24px;
        text-align: center;
        box-shadow: 0 12px 26px rgba(0, 0, 0, 0.28);
        position: relative;
        overflow: hidden;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

        .product-card::before {
            content: "";
            position: absolute;
            top: 0;
            left: 0;
            height: 9px;
            width: 100%;
            background: linear-gradient(90deg, #7b3f20, #d4a017, #7b3f20);
        }

        .product-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 18px 34px rgba(0, 0, 0, 0.35);
        }

    .product-image-box {
        width: 100%;
        height: 210px;
        background-color: #fffaf0;
        border: 1px solid #e2c98d;
        border-radius: 18px;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
        margin-bottom: 20px;
        position: relative;
    }

        .product-image-box img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    .image-placeholder-text {
        display: none;
        color: #8b6f47;
        font-size: 16px;
        font-weight: 700;
    }

    .product-image-box.no-image .image-placeholder-text {
        display: block;
    }

    .product-name {
        color: #2f241d;
        font-size: 24px;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 14px;
        min-height: 62px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .price-box {
        display: inline-block;
        background: linear-gradient(180deg, #ffd84d, #e7a90c);
        color: #3b2a20;
        border: 2px solid #7b3f20;
        border-radius: 14px;
        padding: 10px 22px;
        font-size: 27px;
        font-weight: 900;
        margin-bottom: 22px;
        box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.55), 0 5px 10px rgba(0, 0, 0, 0.18);
    }

    .note-button {
        border: none;
        background: linear-gradient(180deg, #5a3825, #2f1d14);
        color: #fff8df;
        padding: 12px 26px;
        border-radius: 999px;
        font-size: 17px;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 1px;
        cursor: pointer;
        box-shadow: 0 6px 12px rgba(0, 0, 0, 0.25);
    }

        .note-button:hover {
            background: linear-gradient(180deg, #7b3f20, #3b2a20);
            transform: scale(1.04);
        }

    .empty-menu {
        background-color: #f8f5ec;
        color: #3b2a20;
        padding: 24px;
        border-radius: 16px;
        font-weight: 900;
        text-align: center;
        border: 2px solid #d1a856;
    }

    .product-actions {
        margin-top: 18px;
    }

    .detail-button {
        display: inline-block;
        background: linear-gradient(180deg, #5a3825, #2f1d14);
        color: #fff8df;
        padding: 12px 26px;
        border-radius: 999px;
        font-size: 17px;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 1px;
        text-decoration: none;
        box-shadow: 0 6px 12px rgba(0, 0, 0, 0.25);
    }

        .detail-button:hover {
            background: linear-gradient(180deg, #7b3f20, #3b2a20);
            color: white;
        }

    @@media (max-width: 1100px) {
        .filter-form {
            grid-template-columns: 1fr 1fr;
        }
    }

    @@media (max-width: 992px) {
        .product-grid {
            grid-template-columns: repeat(2, minmax(220px, 1fr));
        }
    }

    @@media (max-width: 650px) {
        .menu-page {
            padding: 30px 18px 50px;
        }

        .menu-title {
            margin: -30px -18px 30px;
            font-size: 25px;
        }

        .filter-form {
            grid-template-columns: 1fr;
        }

        .product-grid {
            grid-template-columns: 1fr;
        }

        .category-title {
            font-size: 26px;
        }
    }
</style>

<div class="menu-page">
    <h2 class="menu-title">
        <span>Thực Đơn Ghi Sổ</span>
    </h2>

    <div class="filter-box">
        <div class="filter-title">Tìm kiếm, lọc sản phẩm</div>

        <form asp-controller="Home" asp-action="Index" method="get" class="filter-form">
            <div class="filter-group">
                <label>Tên sản phẩm</label>
                <input type="text"
                       name="keyword"
                       value="@keyword"
                       class="filter-control"
                       placeholder="Nhập tên món..." />
            </div>

            <div class="filter-group">
                <label>Danh mục</label>
                <select name="danhMucId" class="filter-control" asp-items="ViewBag.DanhMucSelectList">
                    <option value="">Tất cả danh mục</option>
                </select>
            </div>

            <div class="filter-group">
                <label>Giá từ</label>
                <input type="number"
                       name="giaTu"
                       value="@giaTu"
                       class="filter-control"
                       placeholder="0" />
            </div>

            <div class="filter-group">
                <label>Giá đến</label>
                <input type="number"
                       name="giaDen"
                       value="@giaDen"
                       class="filter-control"
                       placeholder="50000" />
            </div>

            <button type="submit" class="filter-btn">
                Tìm
            </button>

            <a asp-controller="Home" asp-action="Index" class="reset-btn">
                Xóa lọc
            </a>
        </form>
    </div>

    @if (Model == null || !Model.Any())
    {
        <div class="empty-menu">
            Không tìm thấy sản phẩm phù hợp.
        </div>
    }
    else
    {
        <div class="category-nav">
            <h3>Mục lục</h3>

            <ul class="category-list">
                @foreach (var group in Model.GroupBy(m => m.DanhMuc?.TenDanhMuc ?? "Món khác"))
                {
                    var targetId = Uri.EscapeDataString(group.Key.Replace(" ", "-"));

                    <li>
                        <a href="#@targetId">@group.Key</a>
                    </li>
                }
            </ul>
        </div>

        @foreach (var group in Model.GroupBy(m => m.DanhMuc?.TenDanhMuc ?? "Món khác"))
        {
            var targetId = Uri.EscapeDataString(group.Key.Replace(" ", "-"));

            <section class="category-section" id="@targetId">
                <h3 class="category-title">@group.Key</h3>

                <div class="product-grid">
                    @foreach (var item in group)
                    {
                        var imagePath = "";

                        if (string.IsNullOrWhiteSpace(item.HinhAnh))
                        {
                            imagePath = "";
                        }
                        else if (item.HinhAnh.StartsWith("/") || item.HinhAnh.StartsWith("http"))
                        {
                            imagePath = item.HinhAnh;
                        }
                        else
                        {
                            imagePath = Url.Content("~/images/" + item.HinhAnh);
                        }

                        <div class="product-card">
                            <div class="product-image-box @(string.IsNullOrWhiteSpace(imagePath) ? "no-image" : "")">
                                @if (!string.IsNullOrWhiteSpace(imagePath))
                                {
                                    <img src="@imagePath"
                                         alt="@item.TenSP"
                                         onerror="this.style.display='none'; this.parentElement.classList.add('no-image');" />
                                }

                                <span class="image-placeholder-text">Ảnh sản phẩm</span>
                            </div>

                            <div class="product-name">
                                @item.TenSP
                            </div>

                            <div class="price-box">
                                @item.Gia.ToString("N0") Đ
                            </div>

                            <form asp-controller="DonHang" asp-action="Create" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="sanPhamId" value="@item.MaSP" />

                                <div class="product-actions">
                                    <a asp-controller="Home"
                                       asp-action="Details"
                                       asp-route-id="@item.MaSP"
                                       class="detail-button">
                                        Xem chi tiết
                                    </a>
                                </div>
                            </form>
                        </div>
                    }
                </div>
            </section>
        }
    }
</div>