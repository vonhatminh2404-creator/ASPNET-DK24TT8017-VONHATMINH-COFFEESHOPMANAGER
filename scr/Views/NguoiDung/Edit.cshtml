@model CoffeeShopManager.Models.NguoiDung

@{
    ViewData["Title"] = "Sửa người dùng";

    var danhSachVaiTro = ViewBag.DanhSachVaiTro as List<string> ?? new List<string>
    {
        "User",
        "Admin"
    };
}

<style>
    .form-page {
        min-height: 100vh;
        background: #f5f1e8;
        padding: 45px 30px 70px;
        font-family: 'Merriweather', 'Noto Serif Display', 'Be Vietnam Pro', serif;
    }

    .form-sheet {
        max-width: 820px;
        margin: 0 auto;
        background: #f8f6ef;
        border: 4px solid #4d5c4f;
        padding: 36px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.12);
    }

    .form-title {
        text-align: center;
        color: #8f2f24;
        font-size: 42px;
        font-weight: 900;
        text-transform: uppercase;
        margin-bottom: 18px;
    }

    .form-line {
        border-bottom: 4px dashed #8f2f24;
        margin: 0 auto 30px;
        width: 92%;
    }

    .form-group {
        margin-bottom: 26px;
    }

    .form-label {
        display: block;
        color: #28404a;
        font-size: 19px;
        font-weight: 900;
        margin-bottom: 10px;
    }

    .form-control-custom {
        width: 100%;
        border: none;
        border-bottom: 4px solid #4d5c4f;
        background: transparent;
        padding: 10px 8px;
        font-size: 18px;
        font-weight: 700;
        color: #28404a;
        outline: none;
    }

    .readonly-box {
        color: #6f7680;
        font-size: 18px;
        font-weight: 800;
        border-bottom: 4px solid #4d5c4f;
        padding: 10px 8px 14px;
        min-height: 42px;
        background: rgba(255,255,255,0.35);
    }

    .text-danger {
        color: #dc3545;
        font-weight: 900;
        display: block;
        margin-top: 8px;
    }

    .button-row {
        margin-top: 34px;
        display: flex;
        justify-content: space-between;
        gap: 16px;
        flex-wrap: wrap;
    }

    .back-btn,
    .submit-btn {
        min-width: 170px;
        height: 54px;
        border: 4px solid #4d5c4f;
        font-size: 18px;
        font-weight: 900;
        text-transform: uppercase;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
    }

    .back-btn {
        color: #26404a;
        background: transparent;
    }

        .back-btn:hover {
            background: #e9e3d7;
            color: #26404a;
        }

    .submit-btn {
        background: #2f6fed;
        border-color: #2f6fed;
        color: white;
    }

        .submit-btn:hover {
            background: #1f55bd;
        }
</style>

<div class="form-page">
    <div class="form-sheet">
        <h1 class="form-title">Sửa người dùng</h1>
        <div class="form-line"></div>

        <form asp-controller="NguoiDung" asp-action="Edit" asp-route-id="@Model.MaNguoiDung" method="post">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="All" class="text-danger"></div>

            <div class="form-group">
                <label class="form-label">Mã người dùng:</label>
                <div class="readonly-box">#@Model.MaNguoiDung</div>
            </div>

            <div class="form-group">
                <label class="form-label">Email:</label>
                <div class="readonly-box">@Model.Email</div>
            </div>

            <div class="form-group">
                <label class="form-label">Họ tên:</label>
                <input type="text"
                       name="hoTen"
                       value="@Model.HoTen"
                       class="form-control-custom"
                       placeholder="Nhập họ tên người dùng..." />
            </div>

            <div class="form-group">
                <label class="form-label">Vai trò:</label>

                <select name="vaiTro" class="form-control-custom">
                    @foreach (var vaiTro in danhSachVaiTro)
                    {
                        if (Model.VaiTro == vaiTro)
                        {
                            <option value="@vaiTro" selected>@vaiTro</option>
                        }
                        else
                        {
                            <option value="@vaiTro">@vaiTro</option>
                        }
                    }
                </select>
            </div>

            <div class="button-row">
                <a asp-controller="NguoiDung" asp-action="Index" class="back-btn">
                    ← Trở về
                </a>

                <button type="submit" class="submit-btn">
                    Cập nhật
                </button>
            </div>
        </form>
    </div>
</div>