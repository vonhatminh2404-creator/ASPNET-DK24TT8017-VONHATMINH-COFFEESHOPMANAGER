@model CoffeeShopManager.Models.NguoiDung

@{
    ViewData["Title"] = "Chi tiết người dùng";

    int soDonHang = 0;

    if (ViewBag.SoDonHang != null)
    {
        soDonHang = (int)ViewBag.SoDonHang;
    }
}

<style>
    .detail-page {
        min-height: 100vh;
        background: #f5f1e8;
        padding: 45px 30px 70px;
        font-family: 'Merriweather', 'Noto Serif Display', 'Be Vietnam Pro', serif;
    }

    .detail-sheet {
        max-width: 850px;
        margin: 0 auto;
        background: #f8f6ef;
        border: 4px solid #4d5c4f;
        padding: 36px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.12);
    }

    .detail-title {
        text-align: center;
        color: #8f2f24;
        font-size: 42px;
        font-weight: 900;
        text-transform: uppercase;
        margin-bottom: 18px;
    }

    .detail-line {
        border-bottom: 4px dashed #8f2f24;
        margin: 0 auto 30px;
        width: 92%;
    }

    .info-row {
        margin-bottom: 24px;
    }

    .info-label {
        color: #28404a;
        font-size: 19px;
        font-weight: 900;
        margin-bottom: 8px;
    }

    .info-value {
        color: #6f7680;
        font-size: 18px;
        font-weight: 800;
        border-bottom: 3px solid #4d5c4f;
        padding: 8px 6px 12px;
        min-height: 42px;
    }

    .role-admin {
        color: #b42318;
        font-weight: 900;
    }

    .role-user {
        color: #0b5ed7;
        font-weight: 900;
    }

    .button-row {
        margin-top: 32px;
        display: flex;
        gap: 14px;
        flex-wrap: wrap;
    }

    .back-btn,
    .edit-btn,
    .delete-btn {
        min-width: 150px;
        height: 52px;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-weight: 900;
        text-transform: uppercase;
        border-radius: 6px;
    }

    .back-btn {
        border: 4px solid #4d5c4f;
        color: #26404a;
        background: transparent;
    }

        .back-btn:hover {
            background: #e9e3d7;
            color: #26404a;
        }

    .edit-btn {
        background: #2f6fed;
        color: white;
    }

    .delete-btn {
        background: #dc3545;
        color: white;
    }

        .edit-btn:hover,
        .delete-btn:hover {
            opacity: 0.88;
            color: white;
        }
</style>

<div class="detail-page">
    <div class="detail-sheet">
        <h1 class="detail-title">Chi tiết người dùng</h1>
        <div class="detail-line"></div>

        <div class="info-row">
            <div class="info-label">Mã người dùng:</div>
            <div class="info-value">#@Model.MaNguoiDung</div>
        </div>

        <div class="info-row">
            <div class="info-label">Họ tên:</div>
            <div class="info-value">@Model.HoTen</div>
        </div>

        <div class="info-row">
            <div class="info-label">Email:</div>
            <div class="info-value">@Model.Email</div>
        </div>

        <div class="info-row">
            <div class="info-label">Vai trò:</div>
            <div class="info-value">
                @if (Model.VaiTro == "Admin")
                {
                    <span class="role-admin">Admin</span>
                }
                else
                {
                    <span class="role-user">User</span>
                }
            </div>
        </div>

        <div class="info-row">
            <div class="info-label">Số đơn hàng đã đặt:</div>
            <div class="info-value">@soDonHang</div>
        </div>

        <div class="button-row">
            <a asp-controller="NguoiDung" asp-action="Index" class="back-btn">
                ← Trở về
            </a>

            <a asp-controller="NguoiDung"
               asp-action="Edit"
               asp-route-id="@Model.MaNguoiDung"
               class="edit-btn">
                Sửa
            </a>

            <a asp-controller="NguoiDung"
               asp-action="Delete"
               asp-route-id="@Model.MaNguoiDung"
               class="delete-btn">
                Xóa
            </a>
        </div>
    </div>
</div>